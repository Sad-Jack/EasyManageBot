TELEGRAM_BOT_TOKEN=

# Owner-only access. The bot will silently ignore everyone else.
OWNER_TELEGRAM_ID=

# Where approved posts should be published: @channel_username or numeric chat ID.
TARGET_CHAT_ID=
# Discussion group chat ID for incoming comments handling.
COMMENT_SOURCE_CHAT_ID=
# Review chat ID where comment reply workflow is managed.
COMMENT_REVIEW_CHAT_ID=
# Reply mode: bot (MVP) or user (future Telethon/Pyrogram integration).
COMMENT_REPLY_MODE=bot
# UI language for buttons/texts: ru or en.
UI_LANGUAGE=ru

# Claude Code model for post generation. You still need `claude` CLI login locally.
ANTHROPIC_MODEL=sonnet

# Optional override for local voice transcription model.
VOICE_TRANSCRIPTION_ENABLED=true
VOICE_TRANSCRIPTION_PROVIDER=mlx-whisper
LOCAL_TRANSCRIBE_MODEL=mlx-community/whisper-small-mlx
VOICE_MAX_DURATION_SECONDS=180
VOICE_TMP_DIR=tmp/audio

# polling for local development, webhook for cloud deployment.
BOT_MODE=polling

# Local path to your Obsidian vault.
OBSIDIAN_VAULT_PATH=

# Local SQLite database path.
SQLITE_PATH=.data/posting-assistant.sqlite

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_TO_FILE=true
LOG_FILE_PATH=logs/posting-assistant-bot.log

# Fallback style for post generation when custom style is not set.
DEFAULT_POST_STYLE_PROMPT=Пиши живо и понятно для Telegram. Без канцелярита, с короткими абзацами и практическими выводами.

# Required when BOT_MODE=webhook
TELEGRAM_WEBHOOK_BASE_URL=https://your-domain.example.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
PORT=3000

# Optional prompt and tag catalog overrides
ROLE_PROMPT_PATH=posting_assistant_bot/prompts/role_prompt.txt
STYLE_PROMPT_PATH=posting_assistant_bot/prompts/style_prompt.txt
THEMES_PROMPT_PATH=posting_assistant_bot/prompts/themes_prompt.txt
TAGS_PATH=posting_assistant_bot/prompts/tags.txt
POST_TYPES_CONFIG_PATH=posting_assistant_bot/prompts/post_types.json
